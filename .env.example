PORT=3000

# Hostinger Email SMTP defaults.
# Use the full mailbox address as the SMTP username.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_TIMEOUT_MS=10000
SMTP_USER=trade@kafeko.co.uk
SMTP_PASS=replace-with-hostinger-mailbox-password

MAIL_FROM=trade@kafeko.co.uk
MAIL_TO=trade@kafeko.co.uk
